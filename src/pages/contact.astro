---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/seo/Breadcrumb.astro";
import { COMPANY } from "../data/company";

const isSent = Astro.url.searchParams.get("sent") === "true";
---

<BaseLayout
  title="お問い合わせ"
  description={`${COMPANY.name}へのお問い合わせページ。不用品回収・ハウスクリーニングのご相談・見積もり依頼はこちらから。お電話でも受け付けています。`}
  hideCTA={true}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumb items={[{ name: "お問い合わせ", href: "/contact/" }]} />

    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-4">お問い合わせ</h1>
    <p class="text-gray-600 mb-10">
      お見積もり・ご相談はすべて無料です。お気軽にご連絡ください。
    </p>

    <!-- 電話・営業時間 -->
    <div class="bg-brand-secondary rounded-xl p-6 mb-10 flex flex-col sm:flex-row items-center gap-4">
      <div class="text-center sm:text-left">
        <p class="text-sm text-gray-500 mb-1">お電話でのお問い合わせ</p>
        <a href={COMPANY.telHref} class="text-2xl font-black text-brand-primary hover:text-brand-accent transition-colors">
          {COMPANY.tel}
        </a>
        <p class="text-sm text-gray-500 mt-1">受付時間: {COMPANY.hours}</p>
      </div>
    </div>

    {
      isSent ? (
        <div class="bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
          <div class="text-4xl mb-3">✅</div>
          <h2 class="text-xl font-bold text-green-800 mb-2">送信が完了しました</h2>
          <p class="text-green-700">
            お問い合わせありがとうございます。<br />
            通常1〜2営業日以内にご連絡いたします。
          </p>
          <a href="/" class="inline-block mt-6 text-brand-primary font-bold hover:text-brand-accent transition-colors">
            トップページに戻る
          </a>
        </div>
      ) : (
        <form
          action={`https://formspree.io/f/${COMPANY.formspreeId}`}
          method="POST"
          class="space-y-6"
        >
          {/* ハニーポット（スパム対策） */}
          <input type="text" name="_gotcha" class="hidden" />
          <input type="hidden" name="_next" value={`${COMPANY.siteUrl}/contact/?sent=true`} />

          <div>
            <label for="name" class="block text-sm font-bold text-brand-dark mb-1">
              お名前 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="山田 太郎"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-primary"
            />
          </div>

          <div>
            <label for="tel" class="block text-sm font-bold text-brand-dark mb-1">
              電話番号
            </label>
            <input
              type="tel"
              id="tel"
              name="tel"
              placeholder="000-0000-0000"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-primary"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-bold text-brand-dark mb-1">
              メールアドレス <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="example@mail.com"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-primary"
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-bold text-brand-dark mb-1">
              ご希望のサービス
            </label>
            <select
              id="service"
              name="service"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-primary bg-white"
            >
              <option value="">選択してください</option>
              <option value="不用品回収">不用品回収</option>
              <option value="ハウスクリーニング">ハウスクリーニング</option>
              <option value="両方">両方</option>
              <option value="その他">その他・ご相談</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-bold text-brand-dark mb-1">
              お問い合わせ内容 <span class="text-red-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              placeholder="ご相談内容をお書きください。（例：引越しに伴う不用品の量・場所・ご希望の日程など）"
              class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-brand-primary resize-y"
            />
          </div>

          <p class="text-xs text-gray-500">
            <a href="/privacy/" class="text-brand-primary hover:underline">プライバシーポリシー</a>
            に同意の上、送信してください。
          </p>

          <button
            type="submit"
            class="w-full bg-brand-accent text-white font-bold text-lg py-4 rounded-xl hover:bg-orange-600 transition-colors"
          >
            送信する
          </button>
        </form>
      )
    }
  </div>
</BaseLayout>
