---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/seo/Breadcrumb.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import { AREAS } from "../../data/areas";
import { COMPANY } from "../../data/company";
---

<BaseLayout
  title="対応エリア"
  description={`${COMPANY.name}の対応エリア一覧。不用品回収・ハウスクリーニングに対応しているエリアをご確認ください。`}
>

  <!-- ページヘッダー -->
  <div class="bg-[#0F2952] text-white">
    <div class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-20">
      <Breadcrumb items={[{ name: "対応エリア", href: "/area/" }]} />
      <p class="text-xs font-semibold text-brand-accent uppercase tracking-[0.25em] mt-6 mb-3">Service Area</p>
      <h1 class="text-3xl md:text-5xl font-black mb-4 leading-tight">対応エリア</h1>
      <p class="text-white/70 text-base md:text-lg max-w-xl leading-relaxed">
        以下のエリアで不用品回収・ハウスクリーニングに対応しています。<br />
        エリア外の場合もお気軽にご相談ください。
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-24">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {AREAS.map((area) => (
        <a
          href={`/area/${area.slug}/`}
          class="group bg-white border border-gray-100 rounded-lg p-6 hover:shadow-md hover:border-brand-primary transition-all cursor-pointer"
        >
          <div class="flex items-start justify-between mb-3">
            <div>
              <p class="text-xs text-gray-400 mb-1">{area.prefecture}</p>
              <h2 class="text-xl font-bold text-brand-dark group-hover:text-brand-primary transition-colors">{area.name}</h2>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-300 group-hover:text-brand-primary transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed mb-3">{area.description}</p>
          <p class="text-xs text-gray-400">{area.landmark}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-gray-50 border border-gray-100 text-gray-500 rounded px-2 py-1">不用品回収</span>
            <span class="text-xs bg-gray-50 border border-gray-100 text-gray-500 rounded px-2 py-1">ハウスクリーニング</span>
          </div>
        </a>
      ))}
    </div>

    <!-- エリア外の場合 -->
    <div class="bg-gray-50 border border-gray-100 rounded-lg p-8 text-center">
      <p class="font-bold text-brand-dark mb-2">お住まいのエリアが見つからない場合</p>
      <p class="text-sm text-gray-500 mb-6">対応エリアは随時拡大しています。上記以外のエリアでもまずはお問い合わせください。</p>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 bg-[#0F2952] text-white font-bold px-8 py-3 rounded-md hover:bg-brand-primary transition-colors text-sm cursor-pointer"
      >
        エリア確認のお問い合わせ
      </a>
    </div>

  </div>
</BaseLayout>

<CTABanner />
