---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/seo/Breadcrumb.astro";
import FAQ from "../../components/sections/FAQ.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import { AREAS } from "../../data/areas";
import { COMPANY } from "../../data/company";

export function getStaticPaths() {
  return AREAS.map((area) => ({
    params: { city: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;

const title = `${area.name}の不用品回収・ハウスクリーニング`;
const description = `${area.name}の不用品回収・ハウスクリーニングは${COMPANY.name}へ。最短即日対応、お見積もり無料。${area.description}`;

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: COMPANY.name,
  telephone: COMPANY.tel,
  areaServed: {
    "@type": "City",
    name: area.name,
  },
  url: `${COMPANY.siteUrl}/area/${area.slug}/`,
};
---

<BaseLayout title={title} description={description} schema={areaSchema}>

  <!-- ページヘッダー -->
  <div class="bg-[#0F2952] text-white">
    <div class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-20">
      <Breadcrumb
        items={[
          { name: "対応エリア", href: "/area/" },
          { name: area.name, href: `/area/${area.slug}/` },
        ]}
      />
      <p class="text-xs font-semibold text-brand-accent uppercase tracking-[0.25em] mt-6 mb-3">Service Area</p>
      <h1 class="text-3xl md:text-5xl font-black mb-4 leading-tight">
        {area.name}の<br />不用品回収・ハウスクリーニング
      </h1>
      <p class="text-white/70 text-base md:text-lg max-w-xl leading-relaxed">
        {area.description}<br />
        最短即日対応、お見積もり無料でご対応します。
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-24">

    <!-- このエリアで対応できるサービス -->
    <section class="mb-16">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-[0.2em] mb-4">Services</p>
      <h2 class="text-2xl md:text-3xl font-black text-brand-dark mb-8">
        {area.name}で対応できるサービス
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- 不用品回収 -->
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden">
          <div class="p-6 border-t-4 border-brand-primary">
            <h3 class="text-lg font-bold text-brand-dark mb-2">不用品回収</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">
              家具・家電・引越しゴミなど、一点から部屋まるごとまで。{area.name}全域に最短即日でお伺いします。
            </p>
            <ul class="space-y-1.5 mb-5">
              {["家具・家電の単品回収", "引越し不用品の一括回収", "遺品整理・生前整理", "部屋まるごと片付け"].map((item) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="text-brand-accent font-bold flex-shrink-0">—</span>{item}
                </li>
              ))}
            </ul>
            <a href="/services/junk-removal/" class="text-sm font-bold text-brand-primary hover:text-brand-hover transition-colors">
              不用品回収の詳細 →
            </a>
          </div>
        </div>

        <!-- ハウスクリーニング -->
        <div class="bg-white border border-gray-100 rounded-lg overflow-hidden">
          <div class="p-6 border-t-4 border-brand-primary">
            <h3 class="text-lg font-bold text-brand-dark mb-2">ハウスクリーニング</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">
              エアコン・浴室・キッチンなど各所のプロクリーニング。退去・入居時の清掃も{area.name}全域対応。
            </p>
            <ul class="space-y-1.5 mb-5">
              {["エアコンクリーニング", "浴室・キッチンクリーニング", "退去・入居時クリーニング", "定期清掃・まるごとクリーニング"].map((item) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span class="text-brand-accent font-bold flex-shrink-0">—</span>{item}
                </li>
              ))}
            </ul>
            <a href="/services/house-cleaning/" class="text-sm font-bold text-brand-primary hover:text-brand-hover transition-colors">
              ハウスクリーニングの詳細 →
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- 数字 -->
    <section class="mb-16">
      <div class="grid grid-cols-3 divide-x divide-gray-100 border border-gray-100 rounded-lg">
        {[
          { num: "即日", label: "当日〜翌日対応" },
          { num: "0円", label: "お見積もり無料" },
          { num: "365日", label: "年中無休" },
        ].map((s) => (
          <div class="text-center py-8 px-4">
            <p class="text-3xl md:text-4xl font-black text-brand-primary mb-1">{s.num}</p>
            <p class="text-xs text-gray-400">{s.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- よくある質問 -->
    <section class="mb-16">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-[0.2em] mb-4">FAQ</p>
      <h2 class="text-2xl md:text-3xl font-black text-brand-dark mb-8">よくある質問</h2>
      <FAQ category="general" />
    </section>

    <!-- 他のエリアへのリンク -->
    <section class="mb-16">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-[0.2em] mb-4">Other Areas</p>
      <h2 class="text-2xl font-black text-brand-dark mb-6">他のエリア</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        {AREAS.filter((a) => a.slug !== area.slug).map((a) => (
          <a
            href={`/area/${a.slug}/`}
            class="text-center border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-600 hover:border-brand-primary hover:text-brand-primary transition-colors cursor-pointer"
          >
            {a.name}
          </a>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>

<CTABanner />
