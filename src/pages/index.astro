---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import { SERVICES } from "../data/services";
import { COMPANY } from "../data/company";
import { FAQ_ITEMS } from "../data/faq";
---

<BaseLayout
  title={`${COMPANY.name} | 名古屋市の不用品回収・ハウスクリーニング`}
  description="名古屋市・愛知県の不用品回収・ハウスクリーニングはルネデザインへ。古物商許可取得済み、最短即日対応、お見積もり無料。052-990-3968"
>
  <Hero />

  <!-- ===== 実績バー ===== -->
  <section class="bg-[#0F2952] text-white border-t border-white/10">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-3 divide-x divide-white/10">
        {[
          { num: "即日〜", sub: "翌日", label: "最短対応" },
          { num: "¥0",    sub: "",     label: "見積もり費用" },
          { num: "365",   sub: "日",   label: "年中無休対応" },
        ].map((s) => (
          <div class="text-center py-8 px-4">
            <p class="text-3xl md:text-4xl font-black text-brand-accent leading-none">
              {s.num}<span class="text-lg">{s.sub}</span>
            </p>
            <p class="text-xs text-white/40 mt-2 tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 私たちについて（太い左ボーダー＋非対称レイアウト） ===== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div data-animate>
          <!-- 太い左ボーダーで強調 -->
          <div class="border-l-4 border-brand-accent pl-5 mb-10">
            <p class="text-xs text-brand-accent font-bold mb-2">ルネデザインについて</p>
            <h2 class="text-3xl md:text-4xl font-black text-brand-dark leading-tight">
              「困った」をその日のうちに<br />解決する会社です
            </h2>
          </div>
          <p class="text-gray-600 leading-loose mb-6">
            ルネデザインは名古屋市中村区を拠点に、不用品回収とハウスクリーニングで
            地域の皆様の暮らしをサポートしています。
          </p>
          <p class="text-gray-600 leading-loose mb-10">
            古物商許可（第541052601400号）を取得した事業者として、
            環境への配慮を徹底した適正処理を行っています。
            お電話一本で最短即日対応いたします。
          </p>
          <a href="/about/" class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary border-b border-brand-primary/30 pb-0.5 hover:border-brand-primary transition-colors">
            会社概要を見る →
          </a>
        </div>

        <!-- 特徴リスト（ナンバー付き、余白多め） -->
        <div class="space-y-0 divide-y divide-gray-100" data-animate data-delay="150">
          {[
            { n: "01", title: "最短即日対応", body: "急なご依頼もご連絡ください。スケジュールを調整して最速でお伺いします。" },
            { n: "02", title: "明確な料金体系", body: "追加費用はすべて事前にご説明。見積もり後の変更は一切ありません。" },
            { n: "03", title: "適切な許認可取得", body: "古物商許可（第541052601400号）取得済み。適正処理を徹底します。" },
            { n: "04", title: "年中無休・8〜20時", body: "土日祝日も対応可能。ご都合の良い時間にお伺いします。" },
          ].map((item) => (
            <div class="flex gap-6 py-6">
              <span class="text-2xl font-black text-gray-100 leading-none flex-shrink-0 w-10">{item.n}</span>
              <div>
                <p class="font-bold text-brand-dark mb-1">{item.title}</p>
                <p class="text-sm text-gray-500 leading-relaxed">{item.body}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== 事業内容（写真カード） ===== -->
  <section class="bg-gray-50 py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 md:px-8">

      <div class="flex items-end justify-between mb-12" data-animate>
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-brand-dark">事業内容</h2>
          <p class="text-gray-500 text-sm mt-2">不用品回収からハウスクリーニングまで一貫対応</p>
        </div>
        <a href="/services/" class="text-sm font-bold text-brand-primary border-b border-brand-primary/30 pb-0.5 hidden md:block">
          すべて見る →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          {
            ...SERVICES[0],
            img: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=700&q=80&auto=format&fit=crop",
            imgAlt: "不用品回収イメージ",
            delay: "100",
          },
          {
            ...SERVICES[1],
            img: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=700&q=80&auto=format&fit=crop",
            imgAlt: "ハウスクリーニング作業イメージ",
            delay: "200",
          },
        ].map((service) => (
          <a
            href={service.href}
            class="group bg-white overflow-hidden hover:shadow-lg transition-shadow duration-300"
            data-animate
            data-delay={service.delay}
          >
            <div class="aspect-[16/9] overflow-hidden relative">
              <img
                src={service.img}
                alt={service.imgAlt}
                class="w-full h-full object-cover group-hover:scale-104 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute bottom-0 left-0 right-0 h-1 bg-brand-accent"></div>
            </div>
            <div class="p-8">
              <h3 class="text-xl font-black text-brand-dark mb-2 group-hover:text-brand-primary transition-colors">
                {service.title}
              </h3>
              <p class="text-xs text-gray-400 mb-4 font-medium">{service.subtitle}</p>
              <p class="text-gray-500 text-sm leading-relaxed mb-5">{service.description}</p>
              <ul class="space-y-1.5 mb-6">
                {service.features.map((f) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <span class="text-brand-accent font-black mt-0.5 flex-shrink-0">—</span>
                    {f}
                  </li>
                ))}
              </ul>
              <span class="inline-flex items-center gap-2 text-sm font-bold text-brand-primary group-hover:gap-3 transition-all">
                詳しく見る →
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ===== 利用の流れ（縦タイムライン型） ===== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-4 md:px-8">

      <div class="mb-14" data-animate>
        <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-2">ご利用の流れ</h2>
        <p class="text-gray-500 text-sm">お問い合わせから作業完了まで、シンプルな4ステップです</p>
      </div>

      <div class="space-y-0">
        {[
          { n: "1", title: "お問い合わせ", body: "電話・LINE・メールでご連絡ください。内容をヒアリングし、概算費用をお伝えします。", note: "電話が最速です" },
          { n: "2", title: "現地お見積もり（無料）", body: "ご希望に応じて現地へお伺いし、正確なお見積もりをご提示します。納得いただいてから作業開始。", note: "見積もり費用 ¥0" },
          { n: "3", title: "作業実施", body: "ご指定の日時に伺い、丁寧・迅速に作業を行います。後片付けまで一括で対応します。", note: "" },
          { n: "4", title: "お支払い・完了", body: "作業完了後にお支払いいただきます。現金・カード・PayPay対応。領収書発行可。", note: "" },
        ].map((step, i) => (
          <div class="flex gap-6 relative" data-animate data-delay={String(i * 80)}>
            <!-- 縦線 -->
            <div class="flex flex-col items-center">
              <div class="w-10 h-10 bg-brand-primary text-white font-black text-base flex items-center justify-center flex-shrink-0 z-10">
                {step.n}
              </div>
              {i < 3 && <div class="w-px flex-1 bg-gray-200 my-1"></div>}
            </div>
            <!-- コンテンツ -->
            <div class={`pb-${i < 3 ? "10" : "0"} pt-2 flex-1`}>
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="font-black text-brand-dark text-lg">{step.title}</h3>
                {step.note && (
                  <span class="text-xs font-bold text-brand-accent bg-brand-accent/10 px-2 py-0.5">{step.note}</span>
                )}
              </div>
              <p class="text-sm text-gray-500 leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a href="/flow/" class="text-sm font-bold text-brand-primary border-b border-brand-primary/30 pb-0.5">
          ご利用の流れ詳細を見る →
        </a>
      </div>

    </div>
  </section>

  <!-- ===== お客様の声（引用スタイル） ===== -->
  <section class="bg-gray-50 py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 md:px-8">

      <div class="mb-12" data-animate>
        <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-2">お客様の声</h2>
        <p class="text-gray-500 text-sm">実際にご利用いただいたお客様からのご感想です</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            name: "M.K様（40代・主婦）",
            area: "名古屋市中村区",
            service: "不用品回収",
            body: "引越し前の大量の不用品をすべてお任せできました。電話してから翌日にはお伺いいただき、テキパキと作業を進めてくださいました。料金も事前に明確に教えていただけたので安心でした。",
          },
          {
            name: "T.Y様（50代・会社員）",
            area: "名古屋市西区",
            service: "ハウスクリーニング",
            body: "エアコンと浴室をお願いしました。プロの道具で汚れを落としていただき、驚くほどきれいになりました。作業後に丁寧に仕上がりを確認してくださったのが印象的でした。",
          },
          {
            name: "A.S様（60代・自営業）",
            area: "清須市",
            service: "遺品整理",
            body: "親の家の片付けで途方に暮れていました。大切なものと処分するものを一緒に確認しながら進めていただき、本当に助かりました。",
          },
        ].map((v, i) => (
          <div
            class="bg-white p-8 relative"
            data-animate
            data-delay={String(i * 100)}
          >
            <!-- 大きな引用符 -->
            <div class="text-6xl font-serif text-brand-accent/20 leading-none mb-4 select-none">"</div>
            <p class="text-gray-700 text-sm leading-loose mb-8">{v.body}</p>
            <div class="border-t border-gray-100 pt-5">
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-bold text-brand-dark text-sm">{v.name}</p>
                  <p class="text-xs text-gray-400 mt-0.5">{v.area}</p>
                </div>
                <span class="text-xs font-bold text-white bg-brand-primary px-3 py-1">{v.service}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 md:px-8">

      <div class="mb-12" data-animate>
        <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-2">よくある質問</h2>
        <p class="text-gray-500 text-sm">お問い合わせ前にご確認ください</p>
      </div>

      <div class="space-y-2 mb-10">
        {FAQ_ITEMS.slice(0, 5).map((item, i) => (
          <details class="bg-gray-50 group border-l-4 border-transparent open:border-brand-primary transition-all" data-animate data-delay={String(i * 60)}>
            <summary class="flex items-start justify-between gap-4 px-5 py-5 cursor-pointer list-none">
              <span class="font-bold text-brand-dark text-sm leading-snug">
                <span class="text-brand-accent font-black mr-2">Q.</span>{item.question}
              </span>
              <span class="flex-shrink-0 mt-0.5 w-5 h-5 flex items-center justify-center group-open:rotate-180 transition-transform duration-200">
                <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-sm text-gray-600 leading-relaxed">
                <span class="text-brand-primary font-black mr-2">A.</span>{item.answer}
              </p>
            </div>
          </details>
        ))}
      </div>

      <a href="/faq/" class="text-sm font-bold text-brand-primary border-b border-brand-primary/30 pb-0.5">
        すべてのFAQを見る →
      </a>
    </div>
  </section>

  <!-- ===== 対応エリア（シンプル） ===== -->
  <section class="bg-gray-50 py-16 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row md:items-center gap-8" data-animate>
        <div class="flex-shrink-0">
          <h2 class="text-xl font-black text-brand-dark mb-1">対応エリア</h2>
          <p class="text-gray-500 text-xs">名古屋市中村区を拠点に愛知県全域対応</p>
        </div>
        <div class="flex flex-wrap gap-2">
          {COMPANY.areaServed.map((area) => (
            <span class="text-sm font-medium text-brand-primary bg-white border border-brand-primary/20 px-3 py-1.5">
              {area}
            </span>
          ))}
          <span class="text-sm font-medium text-gray-400 bg-white border border-gray-200 px-3 py-1.5">
            その他エリアもご相談可
          </span>
        </div>
        <a href="/area/" class="flex-shrink-0 text-xs font-bold text-brand-primary border-b border-brand-primary/30 pb-0.5 hidden md:block">
          エリア詳細 →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
