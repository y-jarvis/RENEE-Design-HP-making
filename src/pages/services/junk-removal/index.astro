---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/seo/Breadcrumb.astro";
import FAQ from "../../../components/sections/FAQ.astro";
import CTABanner from "../../../components/sections/CTABanner.astro";
import { COMPANY } from "../../../data/company";

const LP_SERVICES = [
  {
    icon: "🚛",
    title: "不用品回収（一般）",
    subtitle: "一点〜お部屋まるごとまで",
    features: ["最短即日対応", "家具・家電・雑貨なんでもOK", "お見積もり無料"],
    href: "https://www.tokumarushokai.com/lp/",
  },
  {
    icon: "🏠",
    title: "遺品整理・生前整理",
    subtitle: "仕分けから清掃まで一貫対応",
    features: ["買取で費用を相殺", "立会い不要プランあり", "供養の手配も相談可"],
    href: "https://www.tokumarushokai.com/ihin/estate/",
  },
  {
    icon: "📦",
    title: "引越し不用品回収",
    subtitle: "引越し前後の不用品を一括回収",
    features: ["大型家電・家具もOK", "引越し業者と同日対応可", "搬出まで全部お任せ"],
    href: "https://www.tokumarushokai.com/ihin/moving/",
  },
  {
    icon: "🧊",
    title: "冷蔵庫・洗濯機の買取",
    subtitle: "出張査定で費用を削減",
    features: ["出張査定・即日現金払い", "回収費用と相殺可能", "メーカー問わず対応"],
    href: "https://www.tokumarushokai.com/ihin/appliance/",
  },
  {
    icon: "💍",
    title: "ブランド品・貴金属の買取",
    subtitle: "その場で査定・現金払い",
    features: ["ブランドバッグ・時計・貴金属", "金・銀・プラチナ対応", "まとめて査定OK"],
    href: "https://www.tokumarushokai.com/ihin/brand/",
  },
  {
    icon: "❄️",
    title: "エアコンの取外し・買取",
    subtitle: "取外し工事から買取まで",
    features: ["引越し時の取外しも対応", "動作品は買取で費用相殺", "処分のみも可"],
    href: "https://www.tokumarushokai.com/ihin/aircon/",
  },
];

const USE_CASES = [
  "引越し前の急な片付け",
  "実家・親の家の整理",
  "遺品・生前整理",
  "大型家具・家電の処分",
  "ゴミ屋敷・大量片付け",
  "店舗・事務所の閉店整理",
];
---

<BaseLayout
  title="不用品回収"
  description={`${COMPANY.name}の不用品回収サービス。家具・家電・引越しゴミなど一点から部屋丸ごとまで最短即日対応。遺品整理・引越し不用品・家電買取にも対応。お見積もり無料。`}
>
  <!-- ページヘッダー -->
  <div class="bg-[#0F2952] text-white overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[400px]">
      <div class="lg:col-span-7 flex flex-col justify-center px-6 md:px-12 lg:px-16 py-16 lg:py-20">
        <Breadcrumb
          items={[
            { name: "事業内容", href: "/services/" },
            { name: "不用品回収", href: "/services/junk-removal/" },
          ]}
        />
        <p class="text-xs font-semibold text-brand-accent uppercase tracking-[0.25em] mt-6 mb-3">Junk Removal</p>
        <h1 class="text-3xl md:text-5xl font-black mb-4 leading-tight">不用品回収</h1>
        <p class="text-white/70 text-base md:text-lg max-w-xl leading-relaxed">
          家具・家電から引越しゴミまで、一点からお部屋まるごとまで対応。<br />
          最短即日でお伺いし、分別・搬出まで一括でお任せください。
        </p>
      </div>
      <div class="lg:col-span-5 relative hidden lg:block">
        <img
          src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80&auto=format&fit=crop"
          alt="不用品回収・片付け作業イメージ"
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#0F2952] via-[#0F2952]/30 to-transparent"></div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-12">

    <!-- サービスメニュー -->
    <section class="mb-14">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-brand-dark mb-2">サービスメニュー</h2>
        <p class="text-gray-500 text-sm">お困りの内容に合わせてお選びください。詳細ページへご案内します。</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          LP_SERVICES.map((service) => (
            <a
              href={service.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col border border-gray-200 rounded-xl p-6 hover:border-brand-primary hover:shadow-md transition-all bg-white"
            >
              <div class="text-3xl mb-3">{service.icon}</div>
              <h3 class="text-base font-bold text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">
                {service.title}
              </h3>
              <p class="text-xs text-gray-500 mb-4">{service.subtitle}</p>
              <ul class="space-y-1.5 mb-5 flex-1">
                {service.features.map((f) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <span class="text-brand-accent font-bold mt-0.5 shrink-0">✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <span class="flex items-center gap-1 text-sm font-bold text-brand-primary mt-auto">
                詳しく見る
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- サービスの特長 -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-brand-dark mb-6">サービスの特長</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          [
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`, title: "最短即日対応", body: "お電話いただいた当日〜翌日の対応が可能。急なお引越しや大掃除にも対応します。" },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>`, title: "一点〜部屋丸ごとまで", body: "ソファ一点でも、部屋まるごとの片付けでも対応。量に関係なくご相談ください。" },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`, title: "搬出まで一括対応", body: "分別・梱包・搬出まですべて対応。お客様はご立ち合いだけでOKです。" },
            { icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>`, title: "適正処理・リサイクル", body: "家電リサイクル法に基づく適正処理。状態の良いものはリサイクルし環境にも配慮。" },
          ].map((feature) => (
            <div class="bg-brand-secondary rounded-md p-5">
              <div class="mb-3" set:html={feature.icon} />
              <h3 class="font-bold text-brand-dark mb-1">{feature.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{feature.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 主な対応品目 -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-brand-dark mb-6">主な対応品目</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {
          [
            "ソファ・椅子", "ベッド・マットレス", "タンス・棚", "テレビ・モニター",
            "冷蔵庫・洗濯機", "電子レンジ", "パソコン・PC", "自転車・バイク",
            "本・雑誌", "衣類・布団", "食器・雑貨", "引越し荷物まとめて",
          ].map((item) => (
            <div class="bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm text-center text-gray-700">
              {item}
            </div>
          ))
        }
      </div>
      <p class="mt-3 text-sm text-gray-500">※ 上記以外もお気軽にご相談ください</p>
    </section>

    <!-- こんなケースに対応します -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-brand-dark mb-6">こんなケースに対応します</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {
          USE_CASES.map((c) => (
            <div class="flex items-center gap-2 bg-brand-secondary rounded-lg px-4 py-3 text-sm font-medium text-brand-dark">
              <span class="text-brand-accent font-black shrink-0">—</span>
              {c}
            </div>
          ))
        }
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-brand-dark mb-6">よくある質問</h2>
      <FAQ category="junk" />
    </section>

  </div>
</BaseLayout>

<CTABanner />
