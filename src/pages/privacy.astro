---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/seo/Breadcrumb.astro";
import { COMPANY } from "../data/company";
---

<BaseLayout
  title="プライバシーポリシー"
  description={`${COMPANY.name}のプライバシーポリシーページです。`}
  noIndex={true}
  hideCTA={true}
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumb items={[{ name: "プライバシーポリシー", href: "/privacy/" }]} />

    <h1 class="text-3xl font-bold text-brand-dark mb-8">プライバシーポリシー</h1>

    <div class="prose prose-gray max-w-none space-y-8 text-gray-700 leading-relaxed">
      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">個人情報の取り扱いについて</h2>
        <p>
          {COMPANY.name}（以下「当社」）は、お客様の個人情報を適切に保護・管理することを重要な責務と認識し、
          以下のとおりプライバシーポリシーを定めます。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">収集する情報</h2>
        <p>当社は、以下の情報を収集することがあります。</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>お名前・メールアドレス・電話番号（お問い合わせ時）</li>
          <li>ご住所（サービス提供に必要な場合）</li>
          <li>ウェブサイトのアクセスログ・Cookie情報</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">利用目的</h2>
        <p>収集した個人情報は、以下の目的のために利用します。</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>お問い合わせへの対応・サービスの提供</li>
          <li>見積もり・作業日時の連絡</li>
          <li>サービス改善・アンケートのご案内（同意を得た場合）</li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">第三者への提供</h2>
        <p>
          当社は、法令に基づく場合を除き、お客様の同意なく個人情報を第三者に提供することはありません。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">安全管理</h2>
        <p>
          当社は、個人情報の漏洩・紛失・改ざん等を防止するため、適切な安全管理措置を講じます。
        </p>
      </section>

      <section>
        <h2 class="text-xl font-bold text-brand-dark mb-3">お問い合わせ</h2>
        <p>
          個人情報の開示・訂正・削除等のご要望は、下記までお問い合わせください。
        </p>
        <div class="mt-3 bg-brand-secondary rounded-xl p-4 text-sm">
          <p class="font-bold">{COMPANY.name}</p>
          <p>{COMPANY.address.addressRegion}{COMPANY.address.addressLocality}{COMPANY.address.streetAddress}</p>
          <p>TEL: {COMPANY.tel}</p>
          <p>Email: {COMPANY.email}</p>
        </div>
      </section>

      <p class="text-sm text-gray-500">制定日：2025年1月</p>
    </div>
  </div>
</BaseLayout>
