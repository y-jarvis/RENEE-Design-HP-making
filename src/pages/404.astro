---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="ページが見つかりません"
  description="お探しのページは見つかりませんでした。"
  noIndex={true}
>
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <p class="text-8xl font-black text-brand-accent mb-4">404</p>
    <h1 class="text-2xl font-bold text-brand-dark mb-4">ページが見つかりません</h1>
    <p class="text-gray-600 mb-8">
      お探しのページは移動・削除された可能性があります。
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-brand-primary text-white font-bold px-8 py-3 rounded-md hover:bg-[#005a9e] transition-colors"
    >
      トップページに戻る
    </a>
  </div>
</BaseLayout>
