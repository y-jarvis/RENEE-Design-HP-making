---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/seo/Breadcrumb.astro";
import { getCollection } from "astro:content";
import { COMPANY } from "../../data/company";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="お役立ち情報"
  description={`${COMPANY.name}のお役立ち情報。不用品の処分方法・ハウスクリーニングのコツなど、快適な生活に役立つ情報をお届けします。`}
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <Breadcrumb items={[{ name: "お役立ち情報", href: "/blog/" }]} />

    <h1 class="text-3xl md:text-4xl font-bold text-brand-dark mb-4">お役立ち情報</h1>
    <p class="text-gray-600 mb-10">
      不用品の処分方法・ハウスクリーニングのコツなど、役立つ情報をお届けします。
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group bg-white rounded-md shadow-sm hover:shadow-md transition-shadow overflow-hidden"
          >
            <div class="bg-brand-primary h-2 group-hover:bg-brand-accent transition-colors" />
            <div class="p-6">
              <span class="inline-block text-xs bg-brand-secondary text-brand-primary font-bold px-2 py-1 rounded-full mb-3">
                {post.data.category}
              </span>
              <h2 class="font-bold text-brand-dark leading-tight mb-2 group-hover:text-brand-accent transition-colors line-clamp-3">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 line-clamp-2 mb-3">{post.data.description}</p>
              <time
                datetime={post.data.publishDate.toISOString()}
                class="text-xs text-gray-400"
              >
                {post.data.publishDate.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
              </time>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
