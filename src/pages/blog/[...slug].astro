---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/seo/Breadcrumb.astro";
import CTABanner from "../../components/sections/CTABanner.astro";
import { COMPANY } from "../../data/company";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// 前後の記事を取得
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

// 関連記事（同カテゴリ・自分以外・最大3件）
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

// 読了時間の概算（日本語の場合：600字/分）
const { remarkPluginFrontmatter: frontmatter } = await render(post);
const wordCount = post.body?.length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 600));

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  author: {
    "@type": "Organization",
    name: COMPANY.name,
    url: COMPANY.siteUrl,
  },
  publisher: {
    "@type": "Organization",
    name: COMPANY.name,
    url: COMPANY.siteUrl,
  },
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `${COMPANY.siteUrl}/blog/${post.id}/`,
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  schema={articleSchema}
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumb
      items={[
        { name: "お役立ち情報", href: "/blog/" },
        { name: post.data.title, href: `/blog/${post.id}/` },
      ]}
    />

    <article>
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-block text-xs bg-[#0F2952] text-white font-bold px-3 py-1 rounded">
            {post.data.category}
          </span>
          <time datetime={post.data.publishDate.toISOString()} class="text-xs text-gray-400">
            {post.data.publishDate.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          <span class="text-xs text-gray-400">約{readingTime}分で読める</span>
        </div>
        <h1 class="text-2xl md:text-3xl font-bold text-brand-dark leading-tight mb-4">
          {post.data.title}
        </h1>
        <p class="text-gray-500 text-sm leading-relaxed">{post.data.description}</p>

        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag) => (
              <span class="text-xs border border-gray-200 text-gray-500 px-2 py-0.5 rounded">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- 本文 -->
      <div class="prose prose-gray max-w-none
        [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-brand-dark [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:pb-2 [&_h2]:border-b [&_h2]:border-gray-100
        [&_h3]:text-lg [&_h3]:font-bold [&_h3]:text-brand-dark [&_h3]:mt-7 [&_h3]:mb-3
        [&_p]:text-gray-700 [&_p]:leading-[1.9] [&_p]:mb-4
        [&_ul]:space-y-1.5 [&_ul]:mb-5 [&_li]:text-gray-700 [&_li]:leading-relaxed
        [&_ol]:space-y-1.5 [&_ol]:mb-5
        [&_table]:w-full [&_table]:border-collapse [&_table]:mb-6 [&_table]:text-sm
        [&_th]:bg-[#0F2952] [&_th]:text-white [&_th]:px-4 [&_th]:py-2.5 [&_th]:text-left [&_th]:font-bold
        [&_td]:border [&_td]:border-gray-200 [&_td]:px-4 [&_td]:py-2.5 [&_td]:text-gray-700
        [&_strong]:font-bold [&_strong]:text-brand-dark
        [&_hr]:my-10 [&_hr]:border-gray-200
        [&_blockquote]:border-l-4 [&_blockquote]:border-brand-primary [&_blockquote]:pl-5 [&_blockquote]:py-1 [&_blockquote]:text-gray-600 [&_blockquote]:bg-gray-50 [&_blockquote]:rounded-r
      ">
        <Content />
      </div>
    </article>

    <!-- 著者・更新日 -->
    <div class="mt-10 pt-8 border-t border-gray-100 flex items-center gap-4">
      <div class="w-10 h-10 rounded-full bg-[#0F2952] flex items-center justify-center flex-shrink-0">
        <span class="text-white text-xs font-bold">R</span>
      </div>
      <div>
        <p class="text-sm font-bold text-brand-dark">{post.data.author}</p>
        <p class="text-xs text-gray-400">
          公開：{post.data.publishDate.toLocaleDateString("ja-JP")}
          {post.data.updatedDate && (
            <>　更新：{post.data.updatedDate.toLocaleDateString("ja-JP")}</>
          )}
        </p>
      </div>
    </div>

    <!-- 関連記事 -->
    {relatedPosts.length > 0 && (
      <section class="mt-12 pt-10 border-t border-gray-100">
        <h2 class="text-lg font-bold text-brand-dark mb-6">関連記事</h2>
        <div class="space-y-4">
          {relatedPosts.map((related) => (
            <a
              href={`/blog/${related.id}/`}
              class="group flex gap-4 border border-gray-100 rounded-lg p-4 hover:border-brand-primary transition-colors cursor-pointer"
            >
              <div class="flex-1 min-w-0">
                <span class="text-xs text-gray-400 mb-1 block">{related.data.category}</span>
                <p class="text-sm font-bold text-brand-dark group-hover:text-brand-primary transition-colors line-clamp-2 leading-snug">
                  {related.data.title}
                </p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 group-hover:text-brand-primary transition-colors flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 前後の記事 -->
    <nav class="mt-10 pt-8 border-t border-gray-100 grid grid-cols-2 gap-4">
      {prevPost ? (
        <a
          href={`/blog/${prevPost.id}/`}
          class="group flex flex-col gap-1 border border-gray-100 rounded-lg p-4 hover:border-brand-primary transition-colors cursor-pointer"
        >
          <span class="text-xs text-gray-400">← 前の記事</span>
          <span class="text-sm font-medium text-brand-dark group-hover:text-brand-primary transition-colors line-clamp-2 leading-snug">
            {prevPost.data.title}
          </span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a
          href={`/blog/${nextPost.id}/`}
          class="group flex flex-col gap-1 border border-gray-100 rounded-lg p-4 hover:border-brand-primary transition-colors text-right cursor-pointer"
        >
          <span class="text-xs text-gray-400">次の記事 →</span>
          <span class="text-sm font-medium text-brand-dark group-hover:text-brand-primary transition-colors line-clamp-2 leading-snug">
            {nextPost.data.title}
          </span>
        </a>
      ) : <div />}
    </nav>

    <!-- ブログ一覧へ -->
    <div class="mt-8 text-center">
      <a href="/blog/" class="inline-flex items-center gap-2 border border-gray-300 text-gray-600 font-medium text-sm px-6 py-3 rounded-md hover:border-brand-primary hover:text-brand-primary transition-colors cursor-pointer">
        お役立ち情報一覧へ戻る
      </a>
    </div>

  </div>
</BaseLayout>

<CTABanner />
