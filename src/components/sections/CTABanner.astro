---
import { COMPANY } from "../../data/company";
---

<!-- 電話番号中心型CTA（日本BtoCサービス標準形） -->
<section class="bg-brand-accent text-white py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-4">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">

      <!-- 左: コピー + 電話番号 -->
      <div>
        <p class="text-white/70 text-sm font-bold mb-2">まずはお気軽にご相談ください</p>
        <h2 class="text-2xl md:text-3xl font-black mb-6 leading-tight">
          見積もり無料・即日対応<br />
          お電話お待ちしています
        </h2>
        <a
          href={COMPANY.telHref}
          class="inline-flex items-center gap-3 group mb-3"
        >
          <div class="w-10 h-10 bg-white/25 rounded-full flex items-center justify-center flex-shrink-0 group-hover:bg-white/35 transition-colors">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <span class="text-3xl md:text-4xl font-black tracking-[0.06em]">{COMPANY.tel}</span>
        </a>
        <p class="text-white/60 text-xs">受付時間 {COMPANY.hours}</p>
      </div>

      <!-- 右: 3択ボタン -->
      <div class="flex flex-col gap-3">
        <a
          href={COMPANY.telHref}
          class="flex items-center gap-4 bg-white text-brand-accent font-black px-6 py-4 hover:bg-orange-50 transition-colors"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <div>
            <p class="text-xs text-gray-400 font-normal leading-none mb-0.5">最速 — 当日〜翌日対応</p>
            <p class="text-sm">電話で無料相談</p>
          </div>
        </a>

        {COMPANY.lineUrl ? (
          <a
            href={COMPANY.lineUrl}
            class="flex items-center gap-4 bg-[#06C755] text-white font-black px-6 py-4 hover:bg-[#05a847] transition-colors"
          >
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.105.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
            <div>
              <p class="text-xs text-white/70 font-normal leading-none mb-0.5">写真・動画での相談もOK</p>
              <p class="text-sm">LINEで無料相談</p>
            </div>
          </a>
        ) : (
          <a
            href="/contact/"
            class="flex items-center gap-4 bg-white/20 text-white font-black px-6 py-4 hover:bg-white/30 transition-colors border border-white/30"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <div>
              <p class="text-xs text-white/70 font-normal leading-none mb-0.5">24時間受付</p>
              <p class="text-sm">メールで無料相談</p>
            </div>
          </a>
        )}

        <a
          href="/contact/"
          class="flex items-center gap-4 bg-white/15 text-white font-bold px-6 py-4 hover:bg-white/22 transition-colors border border-white/20"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <div>
            <p class="text-xs text-white/60 font-normal leading-none mb-0.5">24時間受付</p>
            <p class="text-sm">無料見積もりフォーム</p>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>
