---
import { COMPANY } from "../../data/company";
---

<section class="bg-brand-primary text-white py-16">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-3">
      まずはお気軽にご相談ください
    </h2>
    <p class="text-brand-secondary mb-8">
      お見積もり無料・年中無休・最短即日対応
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={COMPANY.telHref}
        class="flex items-center justify-center gap-2 bg-white text-brand-primary font-bold text-lg px-8 py-4 rounded-md hover:bg-gray-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {COMPANY.tel}
      </a>
      <a
        href="/contact/"
        class="flex items-center justify-center gap-2 bg-brand-accent text-white font-bold text-lg px-8 py-4 rounded-md hover:bg-orange-600 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        メールで無料相談
      </a>
    </div>
    <p class="mt-4 text-sm text-white/70">
      受付時間: {COMPANY.hours}
    </p>
  </div>
</section>
