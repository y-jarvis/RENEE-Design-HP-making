---
import { COMPANY } from "../../data/company";
---

<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-dark">アクセス・対応エリア</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <!-- 地図 -->
      <div class="rounded-xl overflow-hidden shadow-md aspect-video">
        {
          COMPANY.googleMapsEmbedUrl ? (
            <iframe
              src={COMPANY.googleMapsEmbedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`${COMPANY.name} の地図`}
            />
          ) : (
            <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-500">
              地図を設定してください
            </div>
          )
        }
      </div>

      <!-- 会社情報 -->
      <div class="space-y-4">
        <h3 class="text-xl font-bold text-brand-dark">{COMPANY.name}</h3>

        <dl class="space-y-3 text-sm">
          <div class="flex gap-3">
            <dt class="font-bold text-brand-primary w-20 shrink-0">住所</dt>
            <dd class="text-gray-700">
              〒{COMPANY.address.postalCode}<br />
              {COMPANY.address.addressRegion}{COMPANY.address.addressLocality}{COMPANY.address.streetAddress}
            </dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-bold text-brand-primary w-20 shrink-0">電話</dt>
            <dd>
              <a href={COMPANY.telHref} class="text-brand-primary font-bold hover:text-brand-accent transition-colors">
                {COMPANY.tel}
              </a>
            </dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-bold text-brand-primary w-20 shrink-0">営業時間</dt>
            <dd class="text-gray-700">{COMPANY.hours}</dd>
          </div>
          <div class="flex gap-3">
            <dt class="font-bold text-brand-primary w-20 shrink-0">対応エリア</dt>
            <dd class="text-gray-700">{COMPANY.areaServed.join("・")}</dd>
          </div>
        </dl>

        <a
          href={COMPANY.telHref}
          class="inline-flex items-center justify-center gap-2 bg-brand-accent text-white font-bold px-6 py-3 rounded-xl hover:bg-orange-600 transition-colors w-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {COMPANY.tel} に電話する
        </a>
      </div>
    </div>
  </div>
</section>
