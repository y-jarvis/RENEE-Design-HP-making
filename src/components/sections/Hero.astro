---
import { COMPANY } from "../../data/company";
---

<section class="bg-gradient-to-br from-brand-primary to-[#005a9e] text-white py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-2xl">
      <!-- バッジ -->
      <span class="inline-block bg-brand-accent text-white text-xs font-bold px-3 py-1 rounded-full mb-4">
        お見積もり無料・年中無休
      </span>

      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        不用品回収・<br class="md:hidden" />ハウスクリーニングなら<br />
        <span class="text-brand-accent">{COMPANY.name}</span>
      </h1>

      <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed">
        最短即日対応。一点から部屋丸ごとまで、<br class="hidden md:block" />
        丁寧・迅速・明確な料金でご対応します。
      </p>

      <!-- CTA ボタン -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={COMPANY.telHref}
          class="flex items-center justify-center gap-2 bg-brand-accent text-white font-bold text-lg px-8 py-4 rounded-md hover:bg-orange-600 transition-colors shadow-lg"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          今すぐ無料相談
        </a>
        <a
          href="/services/"
          class="flex items-center justify-center gap-2 bg-white/10 border border-white/30 text-white font-bold text-lg px-8 py-4 rounded-md hover:bg-white/20 transition-colors"
        >
          サービスを見る
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- 受付時間 -->
      <p class="mt-4 text-sm text-white/70">
        受付時間: {COMPANY.hours}
      </p>
    </div>
  </div>
</section>
