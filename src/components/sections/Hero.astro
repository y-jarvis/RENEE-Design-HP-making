---
import { COMPANY } from "../../data/company";
---

<section class="relative bg-[#0F2952] text-white overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[90vh]">

    <!-- 左: テキスト -->
    <div class="lg:col-span-7 flex flex-col justify-center px-6 md:px-12 lg:px-16 xl:px-20 py-20 lg:py-0 relative z-10">

      <!-- エリア表示 -->
      <p class="text-white/40 text-xs font-bold tracking-[0.25em] mb-8">
        名古屋市 / 愛知県全域対応
      </p>

      <!-- メインヘッドライン -->
      <h1 class="text-[2.6rem] md:text-[3.2rem] lg:text-[3.5rem] font-black leading-[1.2] tracking-tight mb-6">
        不用品回収・<br class="sm:hidden" />ハウスクリーニング<br />
        <span class="text-brand-accent">最短即日</span>でお伺いします
      </h1>

      <p class="text-white/55 text-base leading-relaxed mb-10">
        お電話一本で、その日のうちに動きます。
      </p>

      <!-- 電話番号 -->
      <div class="mb-10">
        <p class="text-white/30 text-[10px] font-bold uppercase tracking-[0.3em] mb-3">
          お電話（受付 {COMPANY.hours}）
        </p>
        <a
          href={COMPANY.telHref}
          class="inline-flex items-center gap-3 group"
        >
          <div class="w-9 h-9 bg-brand-accent rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <span class="text-[2rem] md:text-[2.6rem] font-black tracking-[0.06em] group-hover:text-brand-accent transition-colors">
            {COMPANY.tel}
          </span>
        </a>
      </div>

      <!-- CTAボタン -->
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={COMPANY.telHref}
          class="inline-flex items-center justify-center gap-2 bg-brand-accent text-white font-black text-sm px-8 py-4 hover:bg-orange-600 transition-colors"
        >
          今すぐ電話する
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center gap-2 bg-white/10 text-white font-bold text-sm px-8 py-4 border border-white/20 hover:bg-white/15 transition-colors"
        >
          メールで相談する
        </a>
      </div>

    </div>

    <!-- 右: 写真 -->
    <div class="lg:col-span-5 relative hidden lg:block">
      <img
        src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=900&q=85&auto=format&fit=crop"
        alt="清潔感のある明るいリビング"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0F2952] via-[#0F2952]/20 to-transparent"></div>
    </div>

  </div>
</section>
