---
import { FAQ_ITEMS, type FaqItem } from "../../data/faq";
import { COMPANY } from "../../data/company";

interface Props {
  limit?: number;
  category?: FaqItem["category"];
  showSchema?: boolean;
}

const { limit, category, showSchema = false } = Astro.props;

let items = category ? FAQ_ITEMS.filter((f) => f.category === category) : FAQ_ITEMS;
if (limit) items = items.slice(0, limit);

// FAQPage JSON-LD
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<div class="space-y-3">
  {
    items.map((item) => (
      <details class="group bg-white border border-gray-200 rounded-md overflow-hidden">
        <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none font-medium text-brand-dark hover:bg-gray-50 transition-colors">
          <span class="flex items-start gap-3">
            <span class="text-brand-accent font-black text-lg leading-6 shrink-0">Q</span>
            <span>{item.question}</span>
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 shrink-0 text-gray-400 transition-transform group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-6 pb-5 pt-1 flex gap-3 text-gray-700 leading-relaxed border-t border-gray-100">
          <span class="text-brand-primary font-black text-lg leading-6 shrink-0">A</span>
          <p>{item.answer}</p>
        </div>
      </details>
    ))
  }
</div>

{showSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
