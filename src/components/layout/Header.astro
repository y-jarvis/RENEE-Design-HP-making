---
import { COMPANY } from "../../data/company";
import { NAV_LINKS } from "../../data/navigation";

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- ロゴ -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl text-brand-primary">
        <span class="text-brand-accent">R</span>{COMPANY.name}
      </a>

      <!-- PC ナビゲーション -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="グローバルナビゲーション">
        {
          NAV_LINKS.filter((l) => l.label !== "お問い合わせ").map((link) => (
            <a
              href={link.href}
              class={`text-sm font-medium transition-colors hover:text-brand-accent ${
                currentPath.startsWith(link.href) && link.href !== "/"
                  ? "text-brand-accent"
                  : "text-brand-dark"
              }`}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- PC 右側：電話番号 + お問い合わせボタン -->
      <div class="hidden lg:flex items-center gap-4">
        <a href={COMPANY.telHref} class="flex items-center gap-1 text-brand-primary font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {COMPANY.tel}
        </a>
        <a
          href="/contact/"
          class="bg-brand-accent text-white text-sm font-bold px-4 py-2 rounded-lg hover:bg-orange-600 transition-colors"
        >
          無料相談
        </a>
      </div>

      <!-- スマホ ハンバーガーボタン -->
      <button
        id="menu-btn"
        class="lg:hidden p-2 text-brand-dark"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="メニューを開く"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- スマホ メニュー -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white border-t">
    <nav class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-4" aria-label="モバイルナビゲーション">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class={`text-base font-medium py-1 border-b border-gray-100 transition-colors hover:text-brand-accent ${
              currentPath.startsWith(link.href) && link.href !== "/"
                ? "text-brand-accent"
                : "text-brand-dark"
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={COMPANY.telHref}
        class="flex items-center justify-center gap-2 bg-brand-primary text-white font-bold py-3 rounded-lg mt-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {COMPANY.tel} に電話する
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(isOpen));
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });
</script>
