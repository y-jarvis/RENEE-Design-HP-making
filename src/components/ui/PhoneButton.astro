---
import { COMPANY } from "../../data/company";
---

<!-- スマホ固定CTAバー -->
<div class="fixed bottom-0 left-0 right-0 z-50 flex lg:hidden shadow-[0_-2px_10px_rgba(0,0,0,0.15)]">
  <a
    href={COMPANY.telHref}
    class="flex-1 flex items-center justify-center gap-2 bg-brand-primary text-white font-bold text-sm py-4"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    電話で無料相談
  </a>
  <a
    href="/contact/"
    class="flex-1 flex items-center justify-center gap-2 bg-brand-accent text-white font-bold text-sm py-4"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    無料お問い合わせ
  </a>
</div>
